# SMTP settings (use your SMTP provider creds)
SMTP_HOST=smtp.mailprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=you@example.com

# where form emails should go
CONTACT_RECIPIENT=your-personal-email@example.com

# optional server port
PORT=5000